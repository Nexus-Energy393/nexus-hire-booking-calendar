# ------------------------------------------------------------------
# Nexus Generator Hire Booking Calendar - environment variables
# Copy this file to ".env.local" and fill in real values.
# NEVER commit real tokens. .env.local is gitignored.
# Use GitHub Actions secrets for deployment (see README).
# ------------------------------------------------------------------

# --- Pipedrive ---
# Personal/company API token: Pipedrive > Settings > Personal preferences > API
PIPEDRIVE_API_TOKEN=your_pipedrive_api_token_here
# Your Pipedrive company domain (used for deal deep-links and API base)
PIPEDRIVE_COMPANY_DOMAIN=nexusenergy
# The pipeline ID that holds generator HIRE deals. Confirmed: HIRE = 1.
# Only deals in this pipeline are turned into bookings.
PIPEDRIVE_HIRE_PIPELINE_ID=1
# Shared secret you set when creating the Pipedrive webhook (Basic auth user/pass
# or a query token). Used by /api/webhooks/pipedrive to reject forged calls.
PIPEDRIVE_WEBHOOK_SECRET=set_a_long_random_string

# --- Pipedrive custom field keys ---
# Pipedrive custom fields are referenced by a long hash key, not the label.
# Find each key via "npm run list-fields" (GET /v1/dealFields).
# The comments show which live Pipedrive field to map each key to.
PD_FIELD_HIRE_START_DATE=                 # -> "Planned Outage/Hire Start Date" (Date)
PD_FIELD_HIRE_END_DATE=                   # -> "Planned Outage/Hire End Date" (Date)
PD_FIELD_HIRE_DURATION=                   # -> "Estimated Rental Term" (rough bucket; optional)
PD_FIELD_GENERATOR_SIZE=                  # -> "Generator Size Required" or "Generator model"
PD_FIELD_SITE_ADDRESS=                    # -> "Site Address" (Address)
PD_FIELD_JOB_TYPE=                        # -> "Type" (Single option)
PD_FIELD_EQUIPMENT_ALLOCATED=            # -> "SERIAL/FLEET #" (Text)
PD_FIELD_DELIVERY_REQUIRED=               # -> add a Yes/No field in Pipedrive (optional)
PD_FIELD_ELECTRICAL_CONNECTION_REQUIRED=  # -> add a Yes/No field in Pipedrive (optional)

# --- Google Calendar (optional visibility layer) ---
# Leave blank to disable Google Calendar push. See README for service account setup.
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CALENDAR_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Path to the service account JSON key OR the raw JSON (kept out of git).
GOOGLE_SERVICE_ACCOUNT_KEY_JSON=

# --- App ---
# Where the front end fetches bookings from. Leave blank to use sample data only.
NEXT_PUBLIC_API_BASE=
# Auto-refresh interval for the office screen, in seconds.
NEXT_PUBLIC_AUTO_REFRESH_SECONDS=60
# Local booking store location (simple JSON file store by default).
BOOKING_STORE_PATH=./data/bookings.json
