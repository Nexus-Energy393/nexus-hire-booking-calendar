
# ---------------------------------------------------------------
# --- Fleet resourcing (Neon Postgres) ---
# ---------------------------------------------------------------
# Neon connection string. Create a project at https://neon.tech, copy the
# POOLED connection string (it ends with ?sslmode=require). The whole fleet
# resourcing layer (assets, stock, allocations, engine hours, service records,
# alerts) lives here. If DATABASE_URL is unset, the calendar + jobsheet still
# work and the fleet pages show "database not configured" - no fake state.
DATABASE_URL=postgres://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require

# Admin token protecting ALL write actions (asset import, allocation, engine
# hours, service records). Generate a long random string, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Clients send it as: Authorization: Bearer <token>  OR  x-fleet-admin-token: <token>
# If unset, writes are disabled (fail closed). NEVER commit the real value.
FLEET_ADMIN_TOKEN=set_a_long_random_admin_token
# ------------------------------------------------------------------
# Nexus Generator Hire Booking Calendar - environment variables
# Copy this file to ".env.local" and fill in real values.
# NEVER commit real tokens. .env.local is gitignored.
# Use GitHub Actions secrets for deployment (see README).
# ------------------------------------------------------------------

# --- Hire Operations feed (Nexy CRM) ---
# The board reads WON hire-pipeline deals from the Nexy CRM feed. Pipedrive has
# been retired as the data source.
# Feed URL (default is the live CRM; override for staging/local):
HIRE_FEED_URL=https://nexus-crm-gilt.vercel.app/api/hire/calendar
# Optional shared token. If the CRM has HIRE_FEED_TOKEN set, put the SAME value
# here so the board can authenticate. Leave blank if the CRM feed is open.
HIRE_FEED_TOKEN=
# How long (seconds) each warm lambda caches the feed before re-fetching.
BOOKINGS_CACHE_SECONDS=60

# --- App ---
# Where the front end fetches bookings from. Leave blank to use sample data only.
NEXT_PUBLIC_API_BASE=
# Auto-refresh interval for the office screen, in seconds.
NEXT_PUBLIC_AUTO_REFRESH_SECONDS=60
# Local booking store location (simple JSON file store by default).
BOOKING_STORE_PATH=./data/bookings.json
